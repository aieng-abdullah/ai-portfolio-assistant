    {
      "parameters": {
        "description": "Returns the current date and time in ISO format. ALWAYS call this before checking availability or creating a meeting so relative dates like \"tomorrow\" or \"next Monday\" are resolved correctly. Takes no input.",
        "jsCode": "const now = new Date();\nreturn JSON.stringify({\n  iso: now.toISOString(),\n  readable: now.toString(),\n  timezone: Intl.DateTimeFormat().resolvedOptions().timeZone\n});",
        "specifyInputSchema": true,
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {},\n  \"required\": []\n}"
