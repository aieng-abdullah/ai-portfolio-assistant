    {
      "parameters": {
        "description": "Returns the portfolio owner's profile: bio, background, skills, and contact info. Call this for any question about who they are, their skills, experience, or how to contact them. Takes no input.",
        "jsCode": "const profile = {\n  name: \"Your Name\",\n  title: \"Your Title\",\n  bio: \"A short bio about yourself.\",\n  location: \"Remote / Available worldwide\",\n  skills: [\n    \"Skill 1\",\n    \"Skill 2\",\n    \"Skill 3\"\n  ],\n  experience: [\n    \"Your experience bullet 1\",\n    \"Your experience bullet 2\"\n  ],\n  contact: {\n    email: \"you@example.com\",\n    website: \"https://yourwebsite.com\",\n    linkedin: \"https://linkedin.com/in/yourprofile\"\n  }\n};\nreturn JSON.stringify(profile);",
        "specifyInputSchema": true,
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {},\n  \"required\": []\n}"
      },
      "id": "8f5b1556-eee9-4a37-97fa-dd5e28e3865a",
      "name": "get_profile",
      "type": "@n8n/n8n-nodes-langchain.toolCode",
      "typeVersion": 1.3,
      "position": [
        1376,
        416
      ]
    },
    {
      "parameters": {
        "description": "Returns a list of portfolio projects with descriptions and technologies. Call this when a visitor asks about projects, portfolio, or past work. Takes no input.",
        "jsCode": "const projects = [\n  {\n    name: \"Project 1\",\n    description: \"Description of your project.\",\n    technologies: [\"Tech1\", \"Tech2\"]\n  },\n  {\n    name: \"Project 2\",\n    description: \"Description of another project.\",\n    technologies: [\"Tech1\", \"Tech3\"]\n  }\n];\nreturn JSON.stringify(projects);",
        "specifyInputSchema": true,
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {},\n  \"required\": []\n}"
      },
      "id": "83049fde-e3b3-4ee0-be94-4bd6ff9cda38",
