    {
      "parameters": {
        "description": "Returns the services offered, with descriptions. Call this when a visitor asks what services are available, how they can help, or pricing/engagement info. Takes no input.",
        "jsCode": "const services = [\n  {\n    name: \"Service 1\",\n    description: \"Description of your service.\"\n  },\n  {\n    name: \"Service 2\",\n    description: \"Description of another service.\"\n  }\n];\nreturn JSON.stringify(services);",
        "specifyInputSchema": true,
