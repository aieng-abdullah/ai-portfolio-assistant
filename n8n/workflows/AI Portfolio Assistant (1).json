      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Check whether a time slot is free in your Google Calendar before booking. Provide start and end times in ISO 8601 format. Returns whether the slot is available.",
        "resource": "calendar",
        "calendar": {
          "__rl": true,
          "value": "your-email@gmail.com",
