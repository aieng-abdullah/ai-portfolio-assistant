{
  "name": "AI Portfolio Assistant",
  "nodes": [
    {
      "parameters": {
        "public": true,
        "initialMessages": "Hi there! 👋\nI'm your AI Portfolio Assistant. Ask me about my work, or let me help you book a meeting.",
        "options": {
          "allowFileUploads": false,
          "inputPlaceholder": "Type your question..",
          "showWelcomeScreen": true,
          "getStarted": "New Conversation",
          "subtitle": "Ask about my work or book a meeting — available 24/7.",
          "title": "AI Portfolio Assistant",
          "responseMode": "lastNode"
        }
      },
      "id": "f0a906c1-8a95-4671-85c0-bc6ee6826888",
      "name": "When chat message received",
      "type": "@n8n/n8n-nodes-langchain.chatTrigger",
      "typeVersion": 1.4,
      "position": [
        0,
        96
      ],
      "webhookId": ""
    },
    {
      "parameters": {
        "operation": "get",
        "dataTableId": {
          "__rl": true,
          "mode": "id",
          "value": "YOUR_DATA_TABLE_ID"
        },
        "matchType": "allConditions",
        "filters": {
          "conditions": [
            {
              "keyName": "session_id",
              "keyValue": "={{ $json.sessionId }}"
            },
            {
              "keyName": "message_time",
              "condition": "gte",
              "keyValue": "={{ $now.minus(1, 'hour').toISO() }}"
            }
          ]
        },
        "returnAll": true
      },
      "id": "0886bb73-3b07-4a35-a59a-79af424d77db",
      "name": "Count Recent Messages",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [
        224,
        96
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().filter(i => i.json && Object.keys(i.json).length > 0 && i.json.session_id);\nconst count = rows.length;\nconst trigger = $('When chat message received').item.json;\nreturn [{ json: {\n  over_limit: count >= 30,\n  message_count: count,\n  sessionId: trigger.sessionId,\n  chatInput: trigger.chatInput\n} }];"
      },
