# =============================================================
# AI Portfolio Assistant - Environment Variables
# Copy this file to .env and update if needed:
#   cp .env.example .env
# =============================================================

# Database
DATABASE_URL=postgresql://${POSTGRES_USER:-portfolio}:${POSTGRES_PASSWORD:-portfolio_dev}@localhost:${POSTGRES_PORT:-5432}/${POSTGRES_DB:-portfolio}
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_PORT=5432

# n8n
GENERIC_TIMEZONE=UTC
N8N_WEBHOOK_URL=http://localhost:5678/webhook/
N8N_HOST=localhost
N8N_SECURE_COOKIE=false
N8N_ENCRYPTION_KEY=

# API
API_PORT=3000
ENVIRONMENT=development

# LLM
GROQ_API_KEY=

# Google Calendar OAuth (for API token refresh)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=